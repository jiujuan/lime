{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lime",
  "version": "1.54.0",
  "identifier": "com.limecloud.lime",
  "build": {
    "beforeDevCommand": "node scripts/start-tauri-dev-server.mjs",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lime",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "visible": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http://asset.localhost http://tauri.localhost; img-src 'self' asset: tauri: http://asset.localhost data: https: blob: http://localhost:* http://127.0.0.1:* http://[::1]:*; style-src 'self' 'unsafe-inline' asset: http://asset.localhost data: blob:; script-src 'self' 'unsafe-inline' asset: http://asset.localhost; font-src 'self' asset: http://asset.localhost data:; media-src 'self' asset: http://asset.localhost data: blob:; connect-src 'self' tauri: ipc: http://ipc.localhost http://asset.localhost http://tauri.localhost http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:* http://[::1]:* ws://[::1]:* https:; frame-src 'self' asset: http://asset.localhost https: http:; object-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "$HOME/**/*",
            "$TEMP/**/*",
            "$APPDATA/**/*",
            "$APPLOCALDATA/**/*",
            "$APPCACHE/**/*"
          ],
          "deny": [
            "$HOME/.ssh/**/*",
            "$HOME/.aws/**/*",
            "$HOME/.gnupg/**/*",
            "$HOME/.kube/**/*",
            "$HOME/.docker/**/*",
            "$HOME/**/.env",
            "$HOME/**/.env.*"
          ]
        }
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["skill", "skills"],
        "name": "Lime Skill Package",
        "description": "Lime Skill Package",
        "role": "Viewer",
        "mimeType": "application/vnd.lime.skill+zip",
        "rank": "Default",
        "exportedType": {
          "identifier": "com.limecloud.lime.skill",
          "conformsTo": ["public.zip-archive", "public.data"]
        }
      }
    ],
    "resources": [
      "icons/tray/*",
      "resources/site-adapters/**/*",
      "../extensions/lime-chrome/**/*"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": null,
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-",
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "lime-dev-placeholder"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["lime"]
      }
    }
  }
}
