{
  "name": "@limecloud/agent-app-runtime",
  "version": "1.66.0",
  "type": "module",
  "description": "Lime Agent App browser-side runtime SDK: bridge transport, capability adapters, and task orchestration.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/types/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/sdk/index.d.ts",
      "import": "./dist/index.js"
    },
    "./transport": {
      "types": "./dist/types/sdk/hostBridgeClient.d.ts",
      "import": "./dist/hostBridgeClient.js"
    },
    "./adapters": {
      "types": "./dist/types/sdk/capabilityAdapters.d.ts",
      "import": "./dist/capabilityAdapters.js"
    },
    "./projection": {
      "types": "./dist/types/projection.d.ts",
      "import": "./dist/projection.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "sideEffects": false
}
