{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@limecloud/agent-capability-catalog": [
        "../agent-capability-catalog/dist/index.d.ts"
      ]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
