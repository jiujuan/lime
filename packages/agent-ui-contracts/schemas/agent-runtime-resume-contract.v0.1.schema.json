{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limecloud.dev/schemas/agent-runtime-resume-contract.v0.1.schema.json",
  "title": "AgentRuntimeResumeContract",
  "type": "object",
  "required": [
    "schemaVersion",
    "runtimeId",
    "sessionId",
    "turnId",
    "resumeMode",
    "openActionIds",
    "decisions",
    "createdAt"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "lime-runtime-resume-contract/v0.1"
    },
    "runtimeId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "turnId": {
      "type": "string",
      "minLength": 1
    },
    "resumeMode": {
      "type": "string",
      "minLength": 1
    },
    "openActionIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "actionId",
          "decision"
        ],
        "additionalProperties": false,
        "properties": {
          "actionId": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "response": true,
          "metadata": {
            "type": "object"
          }
        }
      }
    },
    "expiresAt": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    }
  }
}
