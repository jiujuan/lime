{
  "extends": "./tsconfig.json",
  "include": ["src"],
  "exclude": [
    "src/test/**",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.testFixtures.ts",
    "src/**/*.testFixtures.tsx",
    "src/**/*.preview.ts",
    "src/**/*.preview.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx"
  ]
}
