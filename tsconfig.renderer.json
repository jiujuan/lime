{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": [
      "node",
      "react",
      "react-dom",
      "react-syntax-highlighter",
      "vite/client",
      "vite-plugin-svgr/client"
    ]
  },
  "include": ["src"],
  "exclude": [
    "src/test/**",
    "src/**/__tests__/**",
    "src/**/*.test/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.testHarness.ts",
    "src/**/*.testHarness.tsx",
    "src/**/*.testMocks.ts",
    "src/**/*.testMocks.tsx",
    "src/**/*.testUtils.ts",
    "src/**/*.testUtils.tsx",
    "src/**/*testUtils.ts",
    "src/**/*testUtils.tsx",
    "src/**/*.testFixtures.ts",
    "src/**/*.testFixtures.tsx",
    "src/**/*TestFixtures.ts",
    "src/**/*TestFixtures.tsx",
    "src/**/test-utils.ts",
    "src/**/test-utils.tsx",
    "src/**/*.preview.ts",
    "src/**/*.preview.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx"
  ]
}
