{
  "$defs": {
    "ThreadGoalStatus": {
      "enum": [
        "active",
        "blocked",
        "budgetLimited",
        "complete",
        "paused",
        "usageLimited"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "createdAt": {
      "format": "int64",
      "type": "integer"
    },
    "objective": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ThreadGoalStatus"
    },
    "threadId": {
      "type": "string"
    },
    "timeUsedSeconds": {
      "format": "int64",
      "type": "integer"
    },
    "tokenBudget": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "tokensUsed": {
      "format": "int64",
      "type": "integer"
    },
    "updatedAt": {
      "format": "int64",
      "type": "integer"
    }
  },
  "required": [
    "createdAt",
    "objective",
    "status",
    "threadId",
    "timeUsedSeconds",
    "tokensUsed",
    "updatedAt"
  ],
  "title": "ThreadGoal",
  "type": "object"
}
