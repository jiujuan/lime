{
  "$defs": {
    "CollaborationMode": {
      "description": "Collaboration mode for a session or turn.",
      "properties": {
        "mode": {
          "$ref": "#/$defs/ModeKind"
        },
        "settings": {
          "$ref": "#/$defs/CollaborationModeSettings"
        }
      },
      "required": [
        "mode",
        "settings"
      ],
      "type": "object"
    },
    "CollaborationModeSettings": {
      "description": "Collaboration mode settings copied from the Codex protocol shape.",
      "properties": {
        "developer_instructions": {
          "type": [
            "null",
            "string"
          ]
        },
        "model": {
          "type": "string"
        },
        "reasoning_effort": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "model"
      ],
      "type": "object"
    },
    "ModeKind": {
      "description": "Initial collaboration mode for a turn or session.",
      "enum": [
        "default",
        "plan"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "approvalPolicy": true,
    "approvalsReviewer": true,
    "collaborationMode": {
      "anyOf": [
        {
          "$ref": "#/$defs/CollaborationMode"
        },
        {
          "type": "null"
        }
      ]
    },
    "cwd": {
      "type": [
        "null",
        "string"
      ]
    },
    "effort": {
      "type": [
        "null",
        "string"
      ]
    },
    "model": {
      "type": [
        "null",
        "string"
      ]
    },
    "permissions": {
      "type": [
        "null",
        "string"
      ]
    },
    "personality": true,
    "sandboxPolicy": true,
    "serviceTier": {
      "type": [
        "null",
        "string"
      ]
    },
    "summary": true,
    "threadId": {
      "type": "string"
    }
  },
  "required": [
    "threadId"
  ],
  "title": "ThreadSettingsUpdateParams",
  "type": "object"
}
