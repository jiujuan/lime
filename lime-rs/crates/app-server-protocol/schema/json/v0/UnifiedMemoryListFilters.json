{
  "$defs": {
    "UnifiedMemoryCategory": {
      "enum": [
        "activity",
        "context",
        "experience",
        "identity",
        "preference"
      ],
      "type": "string"
    },
    "UnifiedMemoryType": {
      "enum": [
        "conversation",
        "project"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "archived": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "category": {
      "anyOf": [
        {
          "$ref": "#/$defs/UnifiedMemoryCategory"
        },
        {
          "type": "null"
        }
      ]
    },
    "limit": {
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "memory_type": {
      "anyOf": [
        {
          "$ref": "#/$defs/UnifiedMemoryType"
        },
        {
          "type": "null"
        }
      ]
    },
    "offset": {
      "format": "uint",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "order": {
      "type": [
        "null",
        "string"
      ]
    },
    "session_id": {
      "type": [
        "null",
        "string"
      ]
    },
    "sort_by": {
      "type": [
        "null",
        "string"
      ]
    }
  },
  "title": "UnifiedMemoryListFilters",
  "type": "object"
}
