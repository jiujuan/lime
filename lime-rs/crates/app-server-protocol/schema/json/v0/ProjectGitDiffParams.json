{
  "$defs": {
    "ProjectGitDiffBase": {
      "enum": [
        "branch",
        "commit",
        "previousConversation",
        "staged",
        "unstaged"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "base": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProjectGitDiffBase"
        },
        {
          "type": "null"
        }
      ]
    },
    "commitSha": {
      "type": [
        "null",
        "string"
      ]
    },
    "contextLines": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "rootPath": {
      "type": "string"
    }
  },
  "required": [
    "rootPath"
  ],
  "title": "ProjectGitDiffParams",
  "type": "object"
}
