{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "fileType": {
      "type": [
        "null",
        "string"
      ]
    },
    "iconDataUrl": {
      "type": [
        "null",
        "string"
      ]
    },
    "isDir": {
      "type": "boolean"
    },
    "isHidden": {
      "default": false,
      "type": "boolean"
    },
    "isSymlink": {
      "default": false,
      "type": "boolean"
    },
    "mimeType": {
      "type": [
        "null",
        "string"
      ]
    },
    "mode": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "modeStr": {
      "type": [
        "null",
        "string"
      ]
    },
    "modifiedAt": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "size": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "isDir",
    "modifiedAt",
    "name",
    "path",
    "size"
  ],
  "title": "FileSystemFileEntry",
  "type": "object"
}
