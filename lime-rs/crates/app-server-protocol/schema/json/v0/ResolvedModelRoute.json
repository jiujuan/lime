        "group": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "isSystem": {
          "type": "boolean"
        },
        "legacyIds": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "location": {
          "type": [
            "null",
            "string"
          ]
        },
        "name": {
          "type": "string"
        },
        "project": {
          "type": [
            "null",
            "string"
          ]
        },
        "promptCacheMode": {
          "type": [
            "null",
            "string"
          ]
        },
        "providerType": {
          "type": "string"
        },
        "region": {
          "type": [
            "null",
            "string"
          ]
        },
        "sortOrder": {
          "format": "int32",
          "type": "integer"
        },
        "updatedAt": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "apiHost",
        "apiKeyCount",
        "enabled",
        "group",
        "id",
        "isSystem",
        "name",
        "providerType",
        "sortOrder"
      ],
      "type": "object"
    },
    "ProviderKeyInfo": {
      "properties": {
        "alias": {
          "type": [
            "null",
            "string"
          ]
        },
        "apiKeyMasked": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "errorCount": {
          "format": "int64",
          "type": "integer"
        },
        "id": {
          "type": "string"
        },
        "lastUsedAt": {
          "type": [
            "null",
            "string"
          ]
        },
        "providerId": {
          "type": "string"
        },
        "usageCount": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "apiKeyMasked",
        "createdAt",
        "enabled",
        "errorCount",
        "id",
        "providerId",
        "usageCount"
      ],
      "type": "object"
    },
    "RouteDefaults": {
      "properties": {
        "forceResponsesApi": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "promptCacheMode": {
          "type": [
            "null",
            "string"
          ]
        },
        "reasoningEffort": {
          "type": [
            "null",
            "string"
          ]
        },
        "toolshim": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "toolshimModel": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "type": "object"
    },
    "RouteFailure": {
      "properties": {
        "capabilityGap": {
          "type": [
            "null",
            "string"
          ]
        },
        "category": {
          "$ref": "#/$defs/RouteFailureCategory"
        },
        "message": {
          "type": [
            "null",
            "string"
          ]
        },
        "modelId": {
          "type": [
            "null",
            "string"
          ]
        },
        "providerId": {
          "type": [
            "null",
            "string"
          ]
        },
        "reasonCode": {
          "type": "string"
        },
        "retryable": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "category",
        "reasonCode"
      ],
      "type": "object"
    },
    "RouteFailureCategory": {
      "enum": [
        "capability_gap",
        "internal_error",
        "missing_credential",
        "model_unavailable",
        "no_candidate",
        "provider_disabled",
        "provider_needs_setup",
        "unsupported_endpoint",
        "unsupported_protocol"
      ],
      "type": "string"
    },
    "RoutingDecision": {
      "properties": {
        "candidateCount": {
          "default": 0,
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "capabilityGap": {
          "type": [
            "null",
            "string"
          ]
        },
        "decisionReason": {
          "type": "string"
        },
        "decisionSource": {
          "type": "string"
        },
        "fallbackChain": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "routingMode": {
          "type": "string"
        },
        "serviceModelSlot": {
          "type": [
            "null",
            "string"
          ]
        },
        "settingsSource": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "decisionReason",
        "decisionSource",
        "routingMode"
      ],
      "type": "object"
    },
    "TransportKind": {
      "enum": [
        "http",
        "local_process",
        "sidecar"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "auth": {
      "$ref": "#/$defs/AuthMaterialRef"
    },
    "capabilitySnapshot": {
      "$ref": "#/$defs/CapabilitySnapshot"
    },
    "decision": {
      "$ref": "#/$defs/RoutingDecision"
    },
    "defaults": {
      "$ref": "#/$defs/RouteDefaults"
    },
    "endpoint": {
      "$ref": "#/$defs/EndpointInfo"
    },
    "failure": {
      "anyOf": [
        {
          "$ref": "#/$defs/RouteFailure"
        },
        {
          "type": "null"
        }
      ]
    },
    "framing": {
      "$ref": "#/$defs/FramingKind"
    },
    "model": {
      "anyOf": [
        {
          "$ref": "#/$defs/ModelInfo"
        },
        {
          "type": "null"
        }
      ]
    },
    "modelRef": {
      "$ref": "#/$defs/ModelRef"
    },
    "protocol": {
      "$ref": "#/$defs/ProtocolKind"
    },
    "provider": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProviderInfo"
        },
        {
          "type": "null"
        }
      ]
    },
    "transport": {
      "$ref": "#/$defs/TransportKind"
    }
  },
  "required": [
    "auth",
    "capabilitySnapshot",
    "decision",
    "defaults",
    "endpoint",
    "framing",
    "modelRef",
    "protocol",
    "transport"
  ],
  "title": "ResolvedModelRoute",
  "type": "object"
}
