{
  "$defs": {
    "SoulStylePackInstallStatus": {
      "enum": [
        "disabled",
        "discovered",
        "downloading",
        "enabled",
        "failed",
        "installed",
        "installing",
        "uninstalled",
        "validating"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "integrityDigest": {
      "type": [
        "null",
        "string"
      ]
    },
    "localeSources": {
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "type": "object"
    },
    "manifestSource": {
      "type": "string"
    },
    "packId": {
      "type": "string"
    },
    "profileIds": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "source": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/SoulStylePackInstallStatus"
    },
    "updatedAt": {
      "type": [
        "null",
        "string"
      ]
    }
  },
  "required": [
    "manifestSource",
    "packId",
    "source",
    "status"
  ],
  "title": "SoulStylePackListEntry",
  "type": "object"
}
