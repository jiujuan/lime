{
  "$defs": {
    "VoiceAsrBaiduConfig": {
      "properties": {
        "api_key": {
          "type": "string"
        },
        "secret_key": {
          "type": "string"
        }
      },
      "required": [
        "api_key",
        "secret_key"
      ],
      "type": "object"
    },
    "VoiceAsrCredential": {
      "properties": {
        "baidu_config": {
          "anyOf": [
            {
              "$ref": "#/$defs/VoiceAsrBaiduConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "disabled": {
          "default": false,
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "is_default": {
          "default": false,
          "type": "boolean"
        },
        "language": {
          "default": "zh",
          "type": "string"
        },
        "name": {
          "type": [
            "null",
            "string"
          ]
        },
        "openai_config": {
          "anyOf": [
            {
              "$ref": "#/$defs/VoiceAsrOpenAiConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "provider": {
          "$ref": "#/$defs/VoiceAsrProviderType"
        },
        "sensevoice_config": {
          "anyOf": [
            {
              "$ref": "#/$defs/VoiceAsrSenseVoiceLocalConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "whisper_config": {
          "anyOf": [
            {
              "$ref": "#/$defs/VoiceAsrWhisperLocalConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "xunfei_config": {
          "anyOf": [
            {
              "$ref": "#/$defs/VoiceAsrXunfeiConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "provider"
      ],
      "type": "object"
    },
    "VoiceAsrOpenAiConfig": {
      "properties": {
        "api_key": {
          "type": "string"
        },
        "base_url": {
          "type": [
            "null",
            "string"
          ]
        },
        "proxy_url": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "api_key"
      ],
      "type": "object"
    },
    "VoiceAsrProviderType": {
      "enum": [
        "baidu",
        "openai",
        "sense_voice_local",
        "whisper_local",
        "xunfei"
      ],
      "type": "string"
    },
    "VoiceAsrSenseVoiceLocalConfig": {
      "properties": {
        "model_dir": {
          "type": [
            "null",
            "string"
          ]
        },
        "model_id": {
          "default": "sensevoice-small-int8-2024-07-17",
          "type": "string"
        },
        "num_threads": {
          "default": 4,
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "use_itn": {
          "default": true,
          "type": "boolean"
        },
        "vad_model_id": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "type": "object"
    },
    "VoiceAsrWhisperLocalConfig": {
      "properties": {
        "model": {
          "$ref": "#/$defs/VoiceAsrWhisperModelSize",
          "default": "base"
        },
        "model_path": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "type": "object"
    },
    "VoiceAsrWhisperModelSize": {
      "enum": [
        "base",
        "medium",
        "small",
        "tiny"
      ],
      "type": "string"
    },
    "VoiceAsrXunfeiConfig": {
      "properties": {
        "api_key": {
          "type": "string"
        },
        "api_secret": {
          "type": "string"
        },
        "app_id": {
          "type": "string"
        }
      },
      "required": [
        "api_key",
        "api_secret",
        "app_id"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "credential": {
      "$ref": "#/$defs/VoiceAsrCredential"
    }
  },
  "required": [
    "credential"
  ],
  "title": "VoiceAsrCredentialUpdateParams",
  "type": "object"
}
