{
  "$defs": {
    "UnifiedMemoryCategory": {
      "enum": [
        "activity",
        "context",
        "experience",
        "identity",
        "preference"
      ],
      "type": "string"
    },
    "UnifiedMemoryHybridSearchOptions": {
      "properties": {
        "category": {
          "anyOf": [
            {
              "$ref": "#/$defs/UnifiedMemoryCategory"
            },
            {
              "type": "null"
            }
          ]
        },
        "keyword_weight": {
          "format": "float",
          "type": [
            "null",
            "number"
          ]
        },
        "limit": {
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "min_similarity": {
          "format": "float",
          "type": [
            "null",
            "number"
          ]
        },
        "query": {
          "type": "string"
        },
        "semantic_weight": {
          "format": "float",
          "type": "number"
        }
      },
      "required": [
        "query",
        "semantic_weight"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "options": {
      "$ref": "#/$defs/UnifiedMemoryHybridSearchOptions"
    }
  },
  "required": [
    "options"
  ],
  "title": "UnifiedMemoryHybridSearchParams",
  "type": "object"
}
