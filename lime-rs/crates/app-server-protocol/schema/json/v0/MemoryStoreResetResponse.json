{
  "$defs": {
    "MemoryStoreScope": {
      "enum": [
        "global",
        "workspace"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "preservedSoul": {
      "type": "boolean"
    },
    "removedDirectories": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "removedFiles": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "rootPath": {
      "type": "string"
    },
    "rootScope": {
      "$ref": "#/$defs/MemoryStoreScope"
    }
  },
  "required": [
    "preservedSoul",
    "removedDirectories",
    "removedFiles",
    "rootPath",
    "rootScope"
  ],
  "title": "MemoryStoreResetResponse",
  "type": "object"
}
