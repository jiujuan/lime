{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "cwd": {
      "type": "string"
    },
    "localEcho": {
      "type": "boolean"
    },
    "pid": {
      "format": "uint32",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "sessionId": {
      "type": "string"
    },
    "shell": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "tty": {
      "type": "boolean"
    }
  },
  "required": [
    "cwd",
    "localEcho",
    "sessionId",
    "shell",
    "title",
    "tty"
  ],
  "title": "ProjectShellSessionStartResponse",
  "type": "object"
}
