{
  "$defs": {
    "EvidencePackArtifact": {
      "properties": {
        "absolutePath": {
          "type": [
            "null",
            "string"
          ]
        },
        "bytes": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "kind": {
          "type": "string"
        },
        "relativePath": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "bytes",
        "kind",
        "relativePath",
        "title"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "artifacts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EvidencePackArtifact"
      },
      "type": "array"
    },
    "completionAuditSummary": true,
    "exportedAt": {
      "type": "string"
    },
    "itemCount": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "knownGaps": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "latestTurnStatus": {
      "type": [
        "null",
        "string"
      ]
    },
    "observabilitySummary": true,
    "packAbsoluteRoot": {
      "type": [
        "null",
        "string"
      ]
    },
    "packRelativeRoot": {
      "type": "string"
    },
    "pendingRequestCount": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "queuedTurnCount": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "recentArtifactCount": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    },
    "threadStatus": {
      "type": "string"
    },
    "turnCount": {
      "format": "uint",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "exportedAt",
    "itemCount",
    "packRelativeRoot",
    "pendingRequestCount",
    "queuedTurnCount",
    "recentArtifactCount",
    "threadStatus",
    "turnCount"
  ],
  "title": "EvidencePackSummary",
  "type": "object"
}
