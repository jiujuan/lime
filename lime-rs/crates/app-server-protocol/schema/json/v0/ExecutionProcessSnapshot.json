{
  "$defs": {
    "ExecutionProcessStatus": {
      "enum": [
        "exited",
        "failed",
        "interrupted",
        "running",
        "starting",
        "terminated"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "elapsedMs": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "exitCode": {
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "failure": {
      "type": [
        "null",
        "string"
      ]
    },
    "outputBytes": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "outputOmittedBytes": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "outputTruncated": {
      "type": "boolean"
    },
    "processId": {
      "type": "string"
    },
    "retainedOutput": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ExecutionProcessStatus"
    },
    "toolId": {
      "type": "string"
    },
    "toolName": {
      "type": "string"
    }
  },
  "required": [
    "elapsedMs",
    "outputBytes",
    "outputOmittedBytes",
    "outputTruncated",
    "processId",
    "retainedOutput",
    "status",
    "toolId",
    "toolName"
  ],
  "title": "ExecutionProcessSnapshot",
  "type": "object"
}
