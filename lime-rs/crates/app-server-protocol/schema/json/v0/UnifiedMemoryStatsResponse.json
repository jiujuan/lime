{
  "$defs": {
    "UnifiedMemoryCategory": {
      "enum": [
        "activity",
        "context",
        "experience",
        "identity",
        "preference"
      ],
      "type": "string"
    },
    "UnifiedMemoryCategoryCount": {
      "properties": {
        "category": {
          "$ref": "#/$defs/UnifiedMemoryCategory"
        },
        "count": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "category",
        "count"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "categories": {
      "default": [],
      "items": {
        "$ref": "#/$defs/UnifiedMemoryCategoryCount"
      },
      "type": "array"
    },
    "memory_count": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "storage_used": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "total_entries": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "memory_count",
    "storage_used",
    "total_entries"
  ],
  "title": "UnifiedMemoryStatsResponse",
  "type": "object"
}
