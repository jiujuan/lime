{
  "$defs": {
    "UnifiedMemorySource": {
      "enum": [
        "auto_extracted",
        "imported",
        "manual"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "access_count": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "confidence": {
      "format": "float",
      "type": "number"
    },
    "embedding": {
      "default": null,
      "items": {
        "format": "float",
        "type": "number"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "importance": {
      "format": "uint8",
      "maximum": 255,
      "minimum": 0,
      "type": "integer"
    },
    "last_accessed_at": {
      "default": null,
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "source": {
      "$ref": "#/$defs/UnifiedMemorySource"
    }
  },
  "required": [
    "access_count",
    "confidence",
    "importance",
    "source"
  ],
  "title": "UnifiedMemoryMetadata",
  "type": "object"
}
