{
  "$defs": {
    "AgentSession": {
      "properties": {
        "appId": {
          "type": "string"
        },
        "businessObjectRef": {
          "anyOf": [
            {
              "$ref": "#/$defs/BusinessObjectRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "createdAt": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/AgentSessionStatus"
        },
        "threadId": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "workspaceId": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "appId",
        "createdAt",
        "sessionId",
        "status",
        "threadId",
        "updatedAt"
      ],
      "type": "object"
    },
    "AgentSessionStatus": {
      "enum": [
        "canceled",
        "completed",
        "failed",
        "idle",
        "running",
        "waitingAction"
      ],
      "type": "string"
    },
    "BusinessObjectRef": {
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "metadata": true,
        "title": {
          "type": [
            "null",
            "string"
          ]
        },
        "uri": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "type": "object"
    },
    "ConversationImportFidelitySummary": {
      "properties": {
        "approvals": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "attachments": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "budgetDropped": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "commands": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "mcp": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "messages": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "patches": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "provenanceOnly": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "reasoning": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "tools": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "unsupported": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "webSearch": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "approvals",
        "attachments",
        "budgetDropped",
        "commands",
        "mcp",
        "messages",
        "patches",
        "provenanceOnly",
        "reasoning",
        "tools",
        "unsupported",
        "webSearch"
      ],
      "type": "object"
    },
    "ConversationImportJob": {
      "properties": {
        "createdAt": {
          "type": "string"
        },
        "error": {
          "type": [
            "null",
            "string"
          ]
        },
        "jobId": {
          "type": "string"
        },
        "progress": {
          "$ref": "#/$defs/ConversationImportJobProgress"
        },
        "result": {
          "anyOf": [
            {
              "$ref": "#/$defs/ConversationImportThreadCommitResponse"
            },
            {
              "type": "null"
            }
          ]
        },
        "sourceClient": {
          "$ref": "#/$defs/ConversationImportSourceClient"
        },
        "sourceThreadId": {
          "type": [
            "null",
            "string"
          ]
        },
        "status": {
          "$ref": "#/$defs/ConversationImportJobStatus"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": [
        "createdAt",
        "jobId",
        "progress",
        "sourceClient",
        "status",
        "updatedAt"
      ],
      "type": "object"
    },
    "ConversationImportJobPhase": {
      "enum": [
        "building_history",
        "completed",
        "failed",
        "finalizing",
        "persisting_history",
        "queued",
        "reading_source"
      ],
      "type": "string"
    },
    "ConversationImportJobProgress": {
      "properties": {
        "completedItems": {
          "default": 0,
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "completedTurns": {
          "default": 0,
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "phase": {
          "$ref": "#/$defs/ConversationImportJobPhase"
        },
        "totalItems": {
          "default": 0,
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "totalTurns": {
          "default": 0,
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "phase"
      ],
      "type": "object"
    },
    "ConversationImportJobStatus": {
      "enum": [
        "completed",
        "failed",
        "queued",
        "running"
      ],
      "type": "string"
    },
    "ConversationImportPreviewDryRun": {
      "properties": {
        "unsupportedItems": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "willAppendToExistingSession": {
          "type": "boolean"
        },
        "willCreateSession": {
          "type": "boolean"
        },
        "willImportAttachments": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "willImportMessages": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "willImportTimelineItems": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "willImportTurns": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "unsupportedItems",
        "willAppendToExistingSession",
        "willCreateSession",
        "willImportAttachments",
        "willImportMessages",
        "willImportTimelineItems",
        "willImportTurns"
      ],
      "type": "object"
    },
    "ConversationImportPreviewSummary": {
      "properties": {
        "dryRun": {
          "$ref": "#/$defs/ConversationImportPreviewDryRun"
        },
        "fidelity": {
          "$ref": "#/$defs/ConversationImportFidelitySummary",
          "default": {
            "approvals": 0,
            "attachments": 0,
            "budgetDropped": 0,
            "commands": 0,
            "mcp": 0,
            "messages": 0,
            "patches": 0,
            "provenanceOnly": 0,
            "reasoning": 0,
            "tools": 0,
            "unsupported": 0,
            "webSearch": 0
          }
        },
        "lineCount": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "messageCount": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "rolloutEventItems": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "truncated": {
          "type": "boolean"
        },
        "unsupportedCount": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "dryRun",
        "lineCount",
        "messageCount",
        "rolloutEventItems",
        "truncated",
        "unsupportedCount"
      ],
      "type": "object"
    },
    "ConversationImportSourceClient": {
      "enum": [
        "codex"
      ],
      "type": "string"
    },
    "ConversationImportThreadCommitResponse": {
      "properties": {
        "canContinue": {
          "type": "boolean"
        },
        "importedMessages": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "importedTurns": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "session": {
          "$ref": "#/$defs/AgentSession"
        },
        "summary": {
          "$ref": "#/$defs/ConversationImportPreviewSummary"
        },
        "thread": {
          "$ref": "#/$defs/ImportedThreadSummary"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "canContinue",
        "importedMessages",
        "importedTurns",
        "session",
        "summary",
        "thread"
      ],
      "type": "object"
    },
    "ConversationImportThreadStatus": {
      "enum": [
        "conflict",
        "imported",
        "importing",
        "not_imported"
      ],
      "type": "string"
    },
    "ImportedThreadSummary": {
      "properties": {
        "archived": {
          "default": false,
          "type": "boolean"
        },
        "createdAt": {
          "type": [
            "null",
            "string"
          ]
        },
        "cwd": {
          "type": [
            "null",
            "string"
          ]
        },
        "importJobId": {
          "type": [
            "null",
            "string"
          ]
        },
        "importStatus": {
          "$ref": "#/$defs/ConversationImportThreadStatus"
        },
        "metadata": true,
        "modelProvider": {
          "type": [
            "null",
            "string"
          ]
        },
        "source": {
          "type": [
            "null",
            "string"
          ]
        },
        "sourceClient": {
          "$ref": "#/$defs/ConversationImportSourceClient"
        },
        "sourcePath": {
          "type": [
            "null",
            "string"
          ]
        },
        "sourceThreadId": {
          "type": "string"
        },
        "title": {
          "type": [
            "null",
            "string"
          ]
        },
        "updatedAt": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "importStatus",
        "sourceClient",
        "sourceThreadId"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "job": {
      "$ref": "#/$defs/ConversationImportJob"
    }
  },
  "required": [
    "job"
  ],
  "title": "ConversationImportJobReadResponse",
  "type": "object"
}
