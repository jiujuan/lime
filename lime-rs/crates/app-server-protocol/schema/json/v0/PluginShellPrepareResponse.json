{
  "$defs": {
    "PluginShellPackageMount": {
      "properties": {
        "kind": {
          "type": "string"
        },
        "manifestHash": {
          "type": "string"
        },
        "packageHash": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "readOnly": {
          "type": "boolean"
        }
      },
      "required": [
        "kind",
        "manifestHash",
        "packageHash",
        "path",
        "readOnly"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "appId": {
      "type": [
        "null",
        "string"
      ]
    },
    "blockerCodes": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "descriptorVersion": {
      "format": "uint64",
      "minimum": 0,
      "type": [
        "integer",
        "null"
      ]
    },
    "devShell": {
      "type": "boolean"
    },
    "entryKey": {
      "type": [
        "null",
        "string"
      ]
    },
    "installMode": {
      "type": [
        "null",
        "string"
      ]
    },
    "message": {
      "type": [
        "null",
        "string"
      ]
    },
    "packageMount": {
      "anyOf": [
        {
          "$ref": "#/$defs/PluginShellPackageMount"
        },
        {
          "type": "null"
        }
      ]
    },
    "preparedAt": {
      "type": "string"
    },
    "shellKind": {
      "type": [
        "null",
        "string"
      ]
    },
    "status": {
      "type": "string"
    },
    "windowTitle": {
      "type": [
        "null",
        "string"
      ]
    }
  },
  "required": [
    "devShell",
    "preparedAt",
    "status"
  ],
  "title": "PluginShellPrepareResponse",
  "type": "object"
}
