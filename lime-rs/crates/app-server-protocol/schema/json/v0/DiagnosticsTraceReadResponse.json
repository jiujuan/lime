  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "available": {
      "type": "boolean"
    },
    "events": {
      "default": [],
      "items": {
        "$ref": "#/$defs/DiagnosticsTraceEvent"
      },
      "type": "array"
    },
    "redaction": {
      "$ref": "#/$defs/DiagnosticsTraceRedactionPolicy"
    },
    "trace": {
      "anyOf": [
        {
          "$ref": "#/$defs/DiagnosticsTraceSummary"
        },
        {
          "type": "null"
        }
      ]
    }
