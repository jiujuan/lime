        "lastWallTimeUnixMs": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "modifiedAt": {
          "type": [
            "null",
            "string"
          ]
        },
        "path": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "sizeBytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "traceId": {
          "type": "string"
        }
