{
  "$defs": {
    "SoulStylePackInstallStatus": {
      "enum": [
        "disabled",
        "discovered",
        "downloading",
        "enabled",
        "failed",
        "installed",
        "installing",
        "uninstalled",
        "validating"
      ],
      "type": "string"
    },
    "SoulStylePackListEntry": {
      "properties": {
        "integrityDigest": {
          "type": [
            "null",
            "string"
          ]
        },
        "localeSources": {
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "type": "object"
        },
        "manifestSource": {
          "type": "string"
        },
        "packId": {
          "type": "string"
        },
        "profileIds": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "source": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/SoulStylePackInstallStatus"
        },
        "updatedAt": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "manifestSource",
        "packId",
        "source",
        "status"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "packs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/SoulStylePackListEntry"
      },
      "type": "array"
    }
  },
  "title": "SoulStylePackListResponse",
  "type": "object"
}
