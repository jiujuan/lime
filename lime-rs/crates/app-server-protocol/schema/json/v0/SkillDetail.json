{
  "$defs": {
    "SkillAuthority": {
      "enum": [
        "application",
        "external",
        "user",
        "workspace"
      ],
      "type": "string"
    },
    "SkillDependencies": {
      "properties": {
        "tools": {
          "items": {
            "$ref": "#/$defs/SkillToolDependency"
          },
          "type": "array"
        }
      },
      "required": [
        "tools"
      ],
      "type": "object"
    },
    "SkillInterface": {
      "properties": {
        "argumentHint": {
          "type": [
            "null",
            "string"
          ]
        },
        "displayName": {
          "type": "string"
        },
        "executionMode": {
          "type": "string"
        },
        "model": {
          "type": [
            "null",
            "string"
          ]
        },
        "provider": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "displayName",
        "executionMode"
      ],
      "type": "object"
    },
    "SkillLocator": {
      "properties": {
        "directory": {
          "type": "string"
        },
        "skillFilePath": {
          "type": "string"
        }
      },
      "required": [
        "directory",
        "skillFilePath"
      ],
      "type": "object"
    },
    "SkillPolicy": {
      "properties": {
        "allowImplicitInvocation": {
          "type": "boolean"
        },
        "whenToUse": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "allowImplicitInvocation"
      ],
      "type": "object"
    },
    "SkillScope": {
      "enum": [
        "app",
        "other",
        "project",
        "user"
      ],
      "type": "string"
    },
    "SkillSource": {
      "enum": [
        "app",
        "other",
        "project",
        "user"
      ],
      "type": "string"
    },
    "SkillSummary": {
      "properties": {
        "authority": {
          "$ref": "#/$defs/SkillAuthority"
        },
        "capabilities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "dependencies": {
          "$ref": "#/$defs/SkillDependencies"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "interface": {
          "$ref": "#/$defs/SkillInterface"
        },
        "locator": {
          "$ref": "#/$defs/SkillLocator"
        },
        "name": {
          "type": "string"
        },
        "policy": {
          "$ref": "#/$defs/SkillPolicy"
        },
        "scope": {
          "$ref": "#/$defs/SkillScope"
        },
        "skillId": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SkillSource"
        }
      },
      "required": [
        "authority",
        "capabilities",
        "dependencies",
        "description",
        "enabled",
        "interface",
        "locator",
        "name",
        "policy",
        "scope",
        "skillId",
        "source"
      ],
      "type": "object"
    },
    "SkillToolDependency": {
      "properties": {
        "required": {
          "type": "boolean"
        },
        "type": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "required",
        "type",
        "value"
      ],
      "type": "object"
    },
    "SkillWorkflowStep": {
      "properties": {
        "dependencies": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "dependencies",
        "id",
        "name"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "markdownContent": {
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/SkillSummary"
    },
    "workflowSteps": {
      "items": {
        "$ref": "#/$defs/SkillWorkflowStep"
      },
      "type": "array"
    }
  },
  "required": [
    "markdownContent",
    "metadata",
    "workflowSteps"
  ],
  "title": "SkillDetail",
  "type": "object"
}
