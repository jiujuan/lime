{
  "$defs": {
    "AgentEvent": {
      "properties": {
        "eventId": {
          "type": "string"
        },
        "payload": true,
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sessionId": {
          "type": "string"
        },
        "threadId": {
          "type": [
            "null",
            "string"
          ]
        },
        "timestamp": {
          "type": "string"
        },
        "turnId": {
          "type": [
            "null",
            "string"
          ]
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "eventId",
        "payload",
        "sequence",
        "sessionId",
        "timestamp",
        "type"
      ],
      "type": "object"
    },
    "AgentSession": {
      "properties": {
        "appId": {
          "type": "string"
        },
        "businessObjectRef": {
          "anyOf": [
            {
              "$ref": "#/$defs/BusinessObjectRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "createdAt": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/AgentSessionStatus"
        },
        "threadId": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "workspaceId": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "appId",
        "createdAt",
        "sessionId",
        "status",
        "threadId",
        "updatedAt"
      ],
      "type": "object"
    },
    "AgentSessionStatus": {
      "enum": [
        "canceled",
        "completed",
        "failed",
        "idle",
        "running",
        "waitingAction"
      ],
      "type": "string"
    },
    "AgentTurn": {
      "properties": {
        "completedAt": {
          "type": [
            "null",
            "string"
          ]
        },
        "sessionId": {
          "type": "string"
        },
        "startedAt": {
          "type": [
            "null",
            "string"
          ]
        },
        "status": {
          "$ref": "#/$defs/AgentTurnStatus"
        },
        "threadId": {
          "type": "string"
        },
        "turnId": {
          "type": "string"
        }
      },
      "required": [
        "sessionId",
        "status",
        "threadId",
        "turnId"
      ],
      "type": "object"
    },
    "AgentTurnStatus": {
      "enum": [
        "accepted",
        "canceled",
        "completed",
        "failed",
        "queued",
        "running",
        "waitingAction"
      ],
      "type": "string"
    },
    "ArtifactContentStatus": {
      "enum": [
        "available",
        "notRequested",
        "unavailable"
      ],
      "type": "string"
    },
    "ArtifactSummary": {
      "properties": {
        "artifactId": {
          "type": [
            "null",
            "string"
          ]
        },
        "artifactRef": {
          "type": "string"
        },
        "content": {
          "type": [
            "null",
            "string"
          ]
        },
        "contentStatus": {
          "$ref": "#/$defs/ArtifactContentStatus",
          "default": "notRequested"
        },
        "eventId": {
          "type": "string"
        },
        "kind": {
          "type": [
            "null",
            "string"
          ]
        },
        "metadata": true,
        "path": {
          "type": [
            "null",
            "string"
          ]
        },
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "status": {
          "type": [
            "null",
            "string"
          ]
        },
        "title": {
          "type": [
            "null",
            "string"
          ]
        },
        "turnId": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "artifactRef",
        "eventId",
        "sequence"
      ],
      "type": "object"
    },
    "BusinessObjectRef": {
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "metadata": true,
        "title": {
          "type": [
            "null",
            "string"
          ]
        },
        "uri": {
          "type": [
            "null",
            "string"
          ]
        }
      },
      "required": [
        "id",
        "kind"
      ],
      "type": "object"
    },
    "EvidencePackArtifact": {
      "properties": {
        "absolutePath": {
          "type": [
            "null",
            "string"
          ]
        },
        "bytes": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "kind": {
          "type": "string"
        },
        "relativePath": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "bytes",
        "kind",
        "relativePath",
        "title"
      ],
      "type": "object"
    },
    "EvidencePackSummary": {
      "properties": {
        "artifacts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/EvidencePackArtifact"
          },
          "type": "array"
        },
        "completionAuditSummary": true,
        "exportedAt": {
          "type": "string"
        },
        "itemCount": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "knownGaps": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "latestTurnStatus": {
          "type": [
            "null",
            "string"
          ]
        },
        "observabilitySummary": true,
        "packAbsoluteRoot": {
          "type": [
            "null",
            "string"
          ]
        },
        "packRelativeRoot": {
          "type": "string"
        },
        "pendingRequestCount": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "queuedTurnCount": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "recentArtifactCount": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "threadStatus": {
          "type": "string"
        },
        "turnCount": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "exportedAt",
        "itemCount",
        "packRelativeRoot",
        "pendingRequestCount",
        "queuedTurnCount",
        "recentArtifactCount",
        "threadStatus",
        "turnCount"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "artifacts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactSummary"
      },
      "type": "array"
    },
    "events": {
      "default": [],
      "items": {
        "$ref": "#/$defs/AgentEvent"
      },
      "type": "array"
    },
    "evidencePack": {
      "anyOf": [
        {
          "$ref": "#/$defs/EvidencePackSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "exportedAt": {
      "type": "string"
    },
    "session": {
      "$ref": "#/$defs/AgentSession"
    },
    "turns": {
      "default": [],
      "items": {
        "$ref": "#/$defs/AgentTurn"
      },
      "type": "array"
    }
  },
  "required": [
    "exportedAt",
    "session"
  ],
  "title": "EvidenceExportResponse",
  "type": "object"
}
