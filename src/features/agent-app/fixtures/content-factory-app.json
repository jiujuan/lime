{
  "manifestVersion": "0.11.0",
  "name": "content-factory-app",
  "displayName": "内容工厂",
  "version": "2.0.0",
  "status": "ready",
  "appType": "domain-app",
  "profiles": ["workbench"],
  "description": "内容工厂是 Agent App v4 生产型应用。Claw 保持中间对话和运行主链，右侧 Product Profile 恢复和操作当前业务产物。",
  "runtimeTargets": ["local"],
  "requires": {
    "sdk": "@lime/app-sdk@^0.11.0",
    "capabilities": [
      "lime.agent",
      "lime.artifacts",
      "lime.evidence",
      "lime.knowledge",
      "lime.media",
      "lime.policy",
      "lime.workflow"
    ]
  },
  "distribution": {
    "primaryInstallSurface": "lime-app-center",
    "channel": "stable",
    "visibility": "public",
    "pricing": "free"
  },
  "presentation": {
    "icon": "./assets/icon.svg",
    "category": "content",
    "accent": "emerald"
  },
  "interface": {
    "displayName": "内容工厂",
    "shortDescription": "在 Claw 中生成文章、图片组、视频分镜和交付清单",
    "longDescription": "内容工厂把写作、资料检索、配图规划和交付审核声明为同一个插件工作流。用户从 @写作 或 @写文章 启动，Claw 展示运行过程，右侧 Product Profile 承载最终文章和后续产物。",
    "category": "content",
    "brandColor": "#10B981",
    "logo": "./assets/icon.svg",
    "composerIcon": "./assets/icon.svg",
    "capabilities": [
      "写作工作流",
      "资料检索",
      "文章草稿",
      "配图规划",
      "交付审核"
    ],
    "defaultPrompt": [
      "@写文章 要求: 帮我写一篇适合公众号发布的文章，先检索和整理依据，最终把正文放到文章草稿小框中。",
      "@写作 要求: 根据我的主题生成一篇文章，展示写作过程，完成后打开右侧文章草稿。",
      "@内容工厂 生成文章、配图规划和交付检查清单，并在右侧 Product Profile 中管理。"
    ],
    "screenshots": []
  },
  "runtimePackage": {
    "worker": {
      "entrypoint": "./src/runtime/content-factory-worker.mjs",
      "contract": "./app.runtime.yaml",
      "sampleRequest": "./examples/runtime-request.sample.json",
      "outputArtifactKind": "content_factory.workspace_patch"
    }
  },
  "agentRuntime": {
    "bridge": {
      "kind": "app-server-json-rpc",
      "required": true
    },
    "intents": [
      {
        "key": "content_article_generate",
        "title": "写文章",
        "aliases": ["@写文章", "@写作"],
        "mode": "natural_language",
        "taskKind": "content.article.generate",
        "outputArtifactKind": "content_factory.workspace_patch",
        "rightSurface": "productProfile",
        "triggerPhrases": {
          "zh-CN": [
            "内容工厂写文章",
            "内容工厂写一篇文章",
            "内容工厂写一篇公众号文章",
            "用内容工厂写文章",
            "用内容工厂生成文章草稿",
            "写文章",
            "写一篇文章",
            "写一篇公众号文章",
            "生成文章草稿"
          ],
          "zh-TW": ["內容工廠寫文章", "用內容工廠寫文章", "寫一篇文章"],
          "en-US": [
            "content factory write article",
            "write an article with content factory",
            "article draft"
          ],
          "ja-JP": ["コンテンツファクトリーで記事を書く"],
          "ko-KR": ["콘텐츠 팩토리로 글쓰기"]
        },
        "expectedObjects": ["articleDraft"]
      },
      {
        "key": "content_factory_generate",
        "mode": "natural_language",
        "taskKind": "content.factory.generate",
        "outputArtifactKind": "content_factory.workspace_patch",
        "rightSurface": "productProfile",
        "triggerPhrases": {
          "zh-CN": ["内容工厂", "用内容工厂生成", "生成文章配图视频分镜"],
          "zh-TW": ["內容工廠", "用內容工廠生成"],
          "en-US": ["content factory", "generate with content factory"],
          "ja-JP": ["コンテンツファクトリー"],
          "ko-KR": ["콘텐츠 팩토리"]
        },
        "expectedObjects": [
          "articleDraft",
          "imageGenerationSet",
          "videoStoryboard",
          "deliveryChecklist"
        ]
      }
    ],
    "workflows": [
      {
        "key": "content_article_workflow",
        "title": "写文章工作流",
        "taskKind": "content.article.generate",
        "triggerIntents": ["content_article_generate"],
        "outputArtifactKind": "content_factory.workspace_patch",
        "cliRefs": ["content-factory"],
        "connectorRefs": ["lime-knowledge", "web-research", "media-generation"],
        "hookPolicy": {
          "prompt": ["prompt-submit"],
          "task": ["task-complete"]
        },
        "steps": [
          {
            "id": "research",
            "title": "资料检索",
            "subagent": "content-researcher",
            "skillRefs": ["gongzonghao-article-writer"],
            "expectedOutput": "写作依据和素材摘要"
          },
          {
            "id": "strategy",
            "title": "选题策划",
            "subagent": "content-strategist",
            "skillRefs": ["gongzonghao-article-writer"],
            "expectedOutput": "文章角度、结构和标题方向"
          },
          {
            "id": "draft",
            "title": "正文写作",
            "subagent": "article-writer",
            "skillRefs": ["gongzonghao-article-writer"],
            "expectedOutput": "articleDraft"
          },
          {
            "id": "review",
            "title": "审稿校对",
            "subagent": "copy-editor",
            "skillRefs": ["gongzonghao-article-writer"],
            "expectedOutput": "deliveryChecklist"
          },
          {
            "id": "image-plan",
            "title": "配图规划",
            "subagent": "image-planner",
            "skillRefs": ["article-image-cheatsheet"],
            "expectedOutput": "imageGenerationSet"
          }
        ]
      }
    ],
    "worker": {
      "entrypoint": "./src/runtime/content-factory-worker.mjs",
      "sampleRequest": "./examples/runtime-request.sample.json",
      "outputArtifactKind": "content_factory.workspace_patch",
      "directProviderAccess": false,
      "directFilesystemAccess": false
    },
    "cli": {
      "entrypoint": "./cli/content-factory.mjs",
      "registry": "./clis/clis.json",
      "commands": ["inspect", "run", "validate"]
    },
    "connectors": {
      "registry": "./connectors/connectors.json"
    },
    "hooks": {
      "directory": "./hooks",
      "handlers": [
        {
          "key": "prompt-submit",
          "event": "prompt.submit",
          "entrypoint": "./hooks/prompt-submit.mjs"
        },
        {
          "key": "task-complete",
          "event": "task.complete",
          "entrypoint": "./hooks/task-complete.mjs"
        }
      ]
    },
    "tasks": [
      {
        "kind": "content.factory.generate"
      },
      {
        "kind": "content.article.generate"
      },
      {
        "kind": "content.image.generate"
      },
      {
        "kind": "content.video.script.generate"
      },
      {
        "kind": "content.video.storyboard.generate"
      },
      {
        "kind": "content.delivery.review"
      }
    ],
    "session": {
      "modes": ["new", "resume", "continue", "fork"],
      "historyRestore": {
        "productWorkspace": "required",
        "fallback": "artifactPreview"
      }
    }
  },
  "storage": {
    "namespace": "content-factory-app",
    "retention": "ask"
  },
  "entries": [
    {
      "key": "content_factory",
      "kind": "workflow",
      "title": "内容工厂",
      "description": "从创作需求生成文章、配图、视频分镜和交付检查清单。",
      "requiredCapabilities": [
        "lime.agent",
        "lime.artifacts",
        "lime.evidence",
        "lime.knowledge",
        "lime.media"
      ]
    }
  ],
  "activationEntries": [
    {
      "key": "content_article_generate",
      "title": "写文章",
      "aliases": ["@写文章", "@写作"],
      "kind": "plugin",
      "intent": "at_command",
      "taskKind": "content.article.generate",
      "workflow": "content_article_workflow",
      "defaultObjectKind": "articleDraft",
      "rightSurface": "productProfile"
    },
    {
      "key": "content_factory_generate",
      "title": "内容工厂",
      "aliases": ["@内容工厂"],
      "kind": "plugin",
      "intent": "at_command",
      "taskKind": "content.factory.generate",
      "workflow": "content_article_workflow",
      "defaultObjectKind": "articleDraft",
      "rightSurface": "productProfile"
    },
    {
      "key": "content_factory",
      "title": "内容工厂",
      "aliases": ["@内容工厂"],
      "kind": "agentApp",
      "intent": "manual",
      "defaultObjectKind": "articleDraft"
    }
  ],
  "artifacts": [
    {
      "key": "content_factory_workspace_patch",
      "type": "content_factory.workspace_patch"
    }
  ],
  "workbench": {
    "profile": "production",
    "productWorkspace": {
      "scope": "session",
      "primaryObjectKinds": [
        "articleDraft",
        "imageGenerationSet",
        "videoStoryboard"
      ],
      "snapshotPolicy": {
        "onArtifactCreated": true,
        "onUserSelectionChanged": true,
        "onSessionClosed": true
      }
    },
    "productionObjects": [
      {
        "kind": "contentBrief",
        "title": "内容简报",
        "artifactKind": "content_brief",
        "defaultSurface": "briefForm",
        "versioning": "revision"
      },
      {
        "kind": "articleDraft",
        "title": "文章草稿",
        "artifactKind": "markdown_document",
        "defaultSurface": "documentCanvas",
        "versioning": "revision",
        "primary": true
      },
      {
        "kind": "imageGenerationSet",
        "title": "图片生成组",
        "artifactKind": "image_set",
        "defaultSurface": "imageGrid",
        "versioning": "snapshot"
      },
      {
        "kind": "videoScript",
        "title": "视频脚本",
        "artifactKind": "video_script",
        "defaultSurface": "documentCanvas",
        "versioning": "revision"
      },
      {
        "kind": "videoStoryboard",
        "title": "视频分镜",
        "artifactKind": "storyboard",
        "defaultSurface": "storyboard",
        "versioning": "revision"
      },
      {
        "kind": "deliveryChecklist",
        "title": "交付检查清单",
        "artifactKind": "delivery_checklist",
        "defaultSurface": "checklist",
        "versioning": "snapshot"
      }
    ],
    "workbenchTasks": [
      {
        "kind": "content.article.generate",
        "title": "生成文章草稿",
        "workflow": "content_article_workflow",
        "subagents": [
          "content-researcher",
          "content-strategist",
          "article-writer",
          "copy-editor",
          "image-planner"
        ],
        "skillRefs": [
          "gongzonghao-article-writer",
          "article-image-cheatsheet"
        ],
        "expectedObjects": ["articleDraft"],
        "defaultSurface": "documentCanvas"
      },
      {
        "kind": "content.image.generate",
        "title": "生成配图",
        "expectedObjects": ["imageGenerationSet"],
        "defaultSurface": "imageGrid"
      },
      {
        "kind": "content.video.script.generate",
        "title": "生成视频脚本",
        "expectedObjects": ["videoScript"],
        "defaultSurface": "documentCanvas"
      },
      {
        "kind": "content.video.storyboard.generate",
        "title": "生成视频分镜",
        "expectedObjects": ["videoStoryboard"],
        "defaultSurface": "storyboard"
      },
      {
        "kind": "content.delivery.review",
        "title": "检查交付内容",
        "expectedObjects": ["deliveryChecklist"],
        "defaultSurface": "checklist",
        "humanReview": true
      }
    ],
    "objectSurfaces": [
      {
        "objectKind": "contentBrief",
        "surfaceKind": "briefForm",
        "title": "内容简报",
        "renderer": "host_builtin",
        "layout": "form"
      },
      {
        "objectKind": "articleDraft",
        "surfaceKind": "documentCanvas",
        "title": "文章草稿",
        "renderer": "host_builtin",
        "layout": "document"
      },
      {
        "objectKind": "imageGenerationSet",
        "surfaceKind": "imageGrid",
        "title": "图片生成组",
        "renderer": "host_builtin",
        "layout": "grid"
      },
      {
        "objectKind": "videoScript",
        "surfaceKind": "documentCanvas",
        "title": "视频脚本",
        "renderer": "host_builtin",
        "layout": "document"
      },
      {
        "objectKind": "videoStoryboard",
        "surfaceKind": "storyboard",
        "title": "视频分镜",
        "renderer": "host_builtin",
        "layout": "storyboard"
      },
      {
        "objectKind": "deliveryChecklist",
        "surfaceKind": "checklist",
        "title": "交付检查清单",
        "renderer": "host_builtin",
        "layout": "checklist"
      }
    ],
    "historyRestore": {
      "defaultSurface": "selectedObject",
      "restoreSelection": true,
      "restoreLayout": true,
      "fallback": "artifactPreview"
    }
  },
  "subagents": [
    {
      "id": "content-researcher",
      "title": "资料检索",
      "description": "围绕主题整理公开资料、用户素材和历史上下文，输出可引用的写作依据。",
      "activation": "content.article.generate",
      "required": true,
      "skills": ["gongzonghao-article-writer"]
    },
    {
      "id": "content-strategist",
      "title": "选题策划",
      "description": "明确读者、角度、标题方向和文章结构，决定首版草稿的主线。",
      "activation": "content.article.generate",
      "required": true,
      "skills": ["gongzonghao-article-writer"]
    },
    {
      "id": "article-writer",
      "title": "正文写作",
      "description": "根据简报和资料生成文章草稿，正文只写入 Product Profile 的文章对象。",
      "activation": "content.article.generate",
      "required": true,
      "skills": ["gongzonghao-article-writer"]
    },
    {
      "id": "copy-editor",
      "title": "审稿校对",
      "description": "检查结构、语气、事实依据和可发布性，生成交付检查项。",
      "activation": "content.delivery.review",
      "required": false,
      "skills": ["gongzonghao-article-writer"]
    },
    {
      "id": "image-planner",
      "title": "配图规划",
      "description": "根据文章段落规划主图、段落图和后续图片生成提示。",
      "activation": "content.image.generate",
      "required": false,
      "skills": ["article-image-cheatsheet"]
    }
  ],
  "skillRefs": [
    {
      "id": "gongzonghao-article-writer",
      "title": "公众号文章写作",
      "description": "根据用户体悟、资料和项目上下文生成自然、低 AI 味的中文长文。",
      "activation": "content.article.generate",
      "required": false
    },
    {
      "id": "article-image-cheatsheet",
      "title": "文章配图规划",
      "description": "根据文章上下文规划中文配图、封面和段落插图。",
      "activation": "content.image.generate",
      "required": false
    }
  ],
  "toolRefs": [
    {
      "key": "content-factory-worker",
      "provider": "local-worker",
      "title": "内容工厂本地 Worker",
      "description": "执行内容工厂受控任务，输出 Product Workspace Patch。",
      "capabilities": [
        "content.article.generate",
        "content.image.generate",
        "content.video.storyboard.generate"
      ],
      "required": false
    }
  ],
  "requirements": "./app.requirements.yaml",
  "boundary": "./app.boundary.yaml",
  "operations": "./app.operations.yaml"
}
