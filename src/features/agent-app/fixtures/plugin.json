{
  "schemaVersion": "lime.plugin.package.v1",
  "id": "content-factory-app",
  "name": "content-factory-app",
  "version": "2.0.0",
  "displayName": "内容工厂",
  "description": "生成文章、配图规划、视频分镜和交付检查清单的内容生产插件。",
  "kind": "domain-plugin",
  "presentation": {
    "icon": "./assets/icon.svg",
    "category": "content",
    "accent": "emerald"
  },
  "install": {
    "local": true,
    "cloud": true,
    "authentication": "on_use"
  },
  "interface": {
    "displayName": "内容工厂",
    "shortDescription": "在 Claw 中生成文章、图片组、视频分镜和交付清单",
    "longDescription": "内容工厂把写作、资料检索、配图规划和交付审核声明为同一个插件工作流。用户从 @写作 或 @写文章 启动，Claw 展示运行过程，右侧 Article Workspace 承载最终文章和后续产物。",
    "category": "content",
    "brandColor": "#10B981",
    "logo": "./assets/icon.svg",
    "composerIcon": "./assets/icon.svg",
    "capabilities": [
      "写作工作流",
      "资料检索",
      "文章草稿",
      "配图规划",
      "交付审核"
    ],
    "defaultPrompt": [
      "@写文章 要求: 帮我写一篇适合公众号发布的文章，先检索和整理依据，最终把正文放到文章草稿小框中。",
      "@写作 要求: 根据我的主题生成一篇文章，展示写作过程，完成后打开右侧文章草稿。",
      "@内容工厂 生成文章、配图规划和交付检查清单，并在右侧 Article Workspace 中管理。"
    ],
    "screenshots": []
  },
  "contributions": {
    "runtime": "./app.runtime.yaml",
    "workbench": "./app.workbench.yaml",
    "skills": "./skills",
    "subagents": "./subagents",
    "clis": "./clis/clis.json",
    "connectors": "./connectors/connectors.json",
    "hooks": "./hooks",
    "resources": "./resources",
    "workflows": "./workflows",
    "artifacts": "./artifacts",
    "locales": "./locales",
    "examples": "./examples"
  }
}
