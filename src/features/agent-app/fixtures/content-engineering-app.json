{
  "manifestVersion": "0.2.0",
  "name": "shenlan-content-engineering",
  "version": "0.1.0",
  "status": "draft",
  "appType": "domain-app",
  "description": "AI 内容工程化 App fixture，用于验证 Agent App P0 只读安装、投影、readiness 和清理计划。",
  "runtimeTargets": ["local"],
  "requires": {
    "lime": {
      "appRuntime": ">=0.2.0 <1.0.0"
    },
    "capabilities": {
      "lime.ui": "^0.1.0",
      "lime.storage": "^0.1.0",
      "lime.agent": "^0.1.0",
      "lime.knowledge": "^0.1.0",
      "lime.artifacts": "^0.1.0",
      "lime.evidence": "^0.1.0"
    }
  },
  "runtimePackage": {
    "ui": { "path": "./dist/ui" },
    "worker": { "path": "./dist/worker" }
  },
  "storage": {
    "namespace": "shenlan-content-engineering",
    "schema": "./storage/schema.json",
    "migrations": "./storage/migrations",
    "retention": "ask"
  },
  "entries": [
    {
      "key": "dashboard",
      "kind": "page",
      "title": "项目首页",
      "description": "查看项目、知识库健康度和内容生产状态。",
      "route": "/dashboard"
    },
    {
      "key": "content_strategist",
      "kind": "expert-chat",
      "title": "内容策略专家",
      "description": "围绕定位、场景和选题给出策略建议。",
      "persona": "./agents/content-strategist.md"
    },
    {
      "key": "scene_exhaustion",
      "kind": "workflow",
      "title": "场景穷尽",
      "description": "从项目资料中穷尽用户场景、痛点和内容切入点。",
      "workflow": "./workflows/exhaust-scenes.workflow.md",
      "requiredCapabilities": ["lime.agent", "lime.knowledge"]
    }
  ],
  "knowledgeTemplates": [
    {
      "key": "ip_knowledge",
      "standard": "agentknowledge",
      "type": "personal-profile",
      "required": false
    },
    {
      "key": "project_knowledge",
      "standard": "agentknowledge",
      "type": "brand-product",
      "required": true
    }
  ],
  "artifacts": [
    {
      "key": "content_table",
      "title": "内容表",
      "type": "table"
    }
  ],
  "policies": [
    {
      "key": "lab_only",
      "title": "P0 只读实验岛",
      "required": true
    }
  ]
}
