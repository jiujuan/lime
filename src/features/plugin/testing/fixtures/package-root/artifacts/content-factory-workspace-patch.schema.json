{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limecloud.dev/schemas/content-factory-workspace-patch.schema.json",
  "title": "ContentFactoryWorkspacePatch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "appId", "sessionId", "objects"],
  "properties": {
    "schemaVersion": {
      "const": "article-workspace.v1"
    },
    "appId": {
      "const": "content-factory-app"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "primaryObjectRef": {
      "$ref": "#/$defs/objectRef"
    },
    "selectedObjectRef": {
      "$ref": "#/$defs/objectRef"
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/productObject"
      }
    },
    "layoutState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activeTabKind": {
          "enum": ["articleWorkspace", "files", "evidence", "shell", "browser", "sideChat"]
        },
        "activePaneKind": {
          "type": "string"
        },
        "openTabKinds": {
          "type": "array",
          "items": {
            "enum": ["articleWorkspace", "files", "evidence", "shell", "browser", "sideChat"]
          }
        },
        "splitMode": {
          "enum": ["chat-right-dock", "chat-only", "article-workspace-collapsed"]
        }
      }
    }
  },
  "$defs": {
    "objectRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["appId", "kind", "id", "sessionId"],
      "properties": {
        "appId": {
          "const": "content-factory-app"
        },
        "kind": {
          "enum": [
            "contentBrief",
            "articleDraft",
            "imageGenerationSet",
            "videoScript",
            "videoStoryboard",
            "deliveryChecklist"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "artifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceTurnId": {
          "type": "string"
        },
        "sourceTaskId": {
          "type": "string"
        }
      }
    },
    "productObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "title", "status", "source"],
      "properties": {
        "ref": {
          "$ref": "#/$defs/objectRef"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "enum": ["draft", "generating", "ready", "needs_review", "archived", "failed"]
        },
        "summary": {
          "type": "string"
        },
        "previewArtifactId": {
          "type": "string"
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "taskKind": {
              "type": "string"
            },
            "taskId": {
              "type": "string"
            },
            "turnId": {
              "type": "string"
            },
            "artifactIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "evidenceIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "processMarkdown": {
              "type": "string"
            },
            "documentText": {
              "type": "string"
            },
            "finalMarkdown": {
              "type": "string"
            },
            "markdown": {
              "type": "string"
            },
            "excerpt": {
              "type": "string"
            },
            "researchRounds": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/researchRound"
              }
            },
            "titleCandidates": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/titleCandidate"
              }
            },
            "outline": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/outlineSection"
              }
            },
            "keyTakeaways": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "imageSlots": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/imageSlot"
              }
            },
            "citations": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/citation"
              }
            },
            "writingPlan": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/writingPlanStep"
              }
            },
            "searchRequests": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/searchRequest"
              }
            },
            "searchEvidence": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/searchEvidence"
              }
            },
            "reviewChecklist": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/reviewChecklistItem"
              }
            },
            "imagePlan": {
              "$ref": "#/$defs/imagePlan"
            },
            "reviewNotes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "images": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/imagePreview"
              }
            },
            "shots": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/storyboardShot"
              }
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/checklistItem"
              }
            },
            "fields": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/previewField"
              }
            }
          }
        }
      }
    },
    "imagePreview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "localPath": {
          "type": "string"
        },
        "filePath": {
          "type": "string"
        },
        "cachedPath": {
          "type": "string"
        },
        "cache": {
          "$ref": "#/$defs/mediaCache"
        },
        "alt": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "slotId": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "sectionId": {
          "type": "string"
        },
        "citationIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "storyboardShot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "visualPrompt": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "cache": {
          "$ref": "#/$defs/mediaCache"
        }
      }
    },
    "mediaCache": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "executor", "kind", "cacheKey", "relativePath", "manifestPath", "mimeType"],
      "properties": {
        "status": {
          "enum": ["pending_executor", "available", "failed"]
        },
        "executor": {
          "const": "content-factory.media-cache.v1"
        },
        "kind": {
          "enum": ["image", "video"]
        },
        "cacheKey": {
          "type": "string",
          "minLength": 1
        },
        "relativePath": {
          "type": "string",
          "minLength": 1
        },
        "manifestPath": {
          "type": "string",
          "minLength": 1
        },
        "mimeType": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "checklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "previewField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "value"],
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "researchRound": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title", "summary"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "query": { "type": "string" },
        "status": { "type": "string" },
        "summary": { "type": "string" },
        "citations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "titleCandidate": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "angle": { "type": "string" },
        "score": { "type": "number" }
      }
    },
    "outlineSection": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "purpose": { "type": "string" },
        "points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidenceIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "imageSlot": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title", "prompt"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "sectionId": { "type": "string" },
        "purpose": { "type": "string" },
        "prompt": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "sourceType": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "writingPlanStep": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "owner": { "type": "string" },
        "skillRef": { "type": "string" },
        "output": { "type": "string" },
        "goal": { "type": "string" },
        "done": { "type": "boolean" }
      }
    },
    "searchRequest": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "query"],
      "properties": {
        "id": { "type": "string" },
        "roundId": { "type": "string" },
        "connectorRef": { "type": "string" },
        "tool": { "type": "string" },
        "query": { "type": "string" },
        "purpose": { "type": "string" },
        "status": { "type": "string" },
        "order": { "type": "number" },
        "expectedOutput": { "type": "string" }
      }
    },
    "searchEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "roundId", "query"],
      "properties": {
        "id": { "type": "string" },
        "roundId": { "type": "string" },
        "connectorRef": { "type": "string" },
        "status": { "type": "string" },
        "query": { "type": "string" },
        "summary": { "type": "string" },
        "citations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": { "type": "string" }
      }
    },
    "reviewChecklistItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "owner": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "imagePlan": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "slots"],
      "properties": {
        "status": { "type": "string" },
        "owner": { "type": "string" },
        "connectorRef": { "type": "string" },
        "slotCount": { "type": "number" },
        "nextAction": { "type": "string" },
        "slots": {
          "type": "array",
          "items": { "$ref": "#/$defs/imageSlot" }
        }
      }
    }
  }
}
