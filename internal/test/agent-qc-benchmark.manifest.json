{
  "schemaVersion": "lime-harbor-benchmark-v1",
  "datasetId": "agent-qc-differential",
  "datasetVersion": "2026-07-02",
  "purpose": "Agent QC baseline / candidate 差异验证计划。默认只声明低成本 deterministic diff，不启动 qcloop、GUI 或 live Provider。",
  "harbor": {
    "localPath": "external/harbor",
    "baselineCommand": "npm run smoke:managed-objective-continuation -- --output .lime/qc/benchmark/managed-objective-baseline.json",
    "candidateCommand": "npm run smoke:managed-objective-continuation -- --output .lime/qc/benchmark/managed-objective-candidate.json"
  },
  "decisionPolicy": {
    "defaultDecision": "deterministic-first",
    "supervisor": "only-when-deterministic-diff-exists",
    "supervisorOutputSchema": "agent-qc-supervisor-verdict-v1",
    "promotionGate": "no-regression-and-evidence-complete"
  },
  "tasks": [],
  "differentialScenarios": [
    {
      "id": "managed-objective-auto-continuation-guard",
      "scenarioId": "managed-objective-auto-continuation-guard",
      "status": "draft",
      "budget": "budget:normal",
      "baseline": {
        "command": "npm run smoke:managed-objective-continuation -- --output .lime/qc/benchmark/managed-objective-baseline.json",
        "evidenceRef": "recent-green-or-baseline-sidecar"
      },
      "candidate": {
        "command": "npm run smoke:managed-objective-continuation -- --output .lime/qc/benchmark/managed-objective-candidate.json",
        "evidenceRef": "candidate-flag-on-sidecar"
      },
      "requiredEvidence": [
        "turn count",
        "objective status",
        "guard decision",
        "evidence pack summary"
      ],
      "deterministicAssertions": [
        "candidate must not create unexpected extra turns",
        "candidate must not consume pending request",
        "candidate must keep budget_limited / needs_input / paused fail-closed"
      ],
      "failureModes": [
        "unexpected auto continuation",
        "pending request consumed",
        "budget limit bypassed",
        "missing evidence pack summary"
      ],
      "supervisorRubric": {
        "enabled": "on-diff-only",
        "input": "baseline/candidate diff summary",
        "humanReview": [
          "projection-only text change",
          "near-threshold semantic score",
          "deterministic diff cannot classify regression"
        ]
      }
    }
  ],
  "backlog": [
    {
      "id": "claw-streaming-cancel-differential",
      "reason": "需要先稳定 runtime transcript 和 GUI trace 对齐口径"
    }
  ]
}
